<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RMA - Repair Merchandise Authorization</title>
<style>
@page { size: A4 portrait; margin: 8mm 8mm 8mm 8mm; }
* { margin: 0; padding: 0; box-sizing: border-box; }
body, html { font-family: 'Calibri', 'Carlito', Arial, sans-serif; font-size: 9.5px; color: #000; line-height: 1.3; }
body { max-width: 210mm; margin: 0 auto; background: #fff; }

.page {
width: 100%;
padding: 4mm 4mm;
border: 2px solid #000;
position: relative;
min-height: 277mm;
background: white;
overflow: hidden;
}

/* WATERMARK — LARGE */
.watermark {
position: absolute;
top: 50%; left: 50%;
transform: translate(-50%, -50%) rotate(-30deg);
opacity: 0.10;
pointer-events: none;
z-index: 0;
width: 580px;
max-width: 85%;
}
.watermark img { width: 100%; display: block; }

.content { position: relative; z-index: 1; }

/* HEADER */
.hdr-copy { text-align: right; font-size: 8px; font-weight: bold; color: #555; margin-bottom: 1px; }
.hdr-title {
text-align: center; font-size: 14px; font-weight: bold;
text-decoration: underline; letter-spacing: 1.5px;
margin: 2px 0 5px;
}
.hdr-tbl { width: 100%; border-collapse: collapse; margin-bottom: 0; }
.hdr-tbl td { border: none; padding: 1px 3px; vertical-align: middle; }
.hdr-logo-cell { width: 18%; text-align: left; vertical-align: top; padding-left: 2px; padding-top: 3px; }
.hdr-logo-img { height: 36px; width: auto; display: block; }
.hdr-company { font-size: 17px; font-weight: bold; letter-spacing: 0.3px; }
.hdr-addr { font-size: 8px; line-height: 1.4; margin-top: 2px; color: #222; }
.hdr-divider { border: none; border-top: 1.5px solid #000; margin: 3px 0 0; }
.hdr-contact {
text-align: center; font-size: 9px; font-weight: bold;
padding: 3px 0; margin-bottom: 4px;
border-bottom: 1.5px solid #000;
background: #eaf4fb; letter-spacing: 0.3px;
}

/* META / DETAIL CELLS — LABEL ON TOP, VALUE BELOW */
.rma-meta { width: 100%; border-collapse: collapse; border: 1.5px solid #000; margin-bottom: 4px; }
.rma-meta td { padding: 4px 8px; vertical-align: top; }
.meta-lbl { font-size: 7.5px; color: #555; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; display: block; }
.meta-val { font-size: 11px; font-weight: bold; color: #000; display: block; margin-top: 2px; }
.rma-meta tr + tr td { border-top: 1px solid #ccc; }
.rma-meta .highlight-cell { background: #eaf4fb; }

/* SECTION BARS */
.sec-bar {
background: #4a90c4; color: #fff;
padding: 3px 8px; font-size: 9px; font-weight: bold;
letter-spacing: 0.5px; text-transform: uppercase; margin-top: 4px;
}

/* ITEM DETAIL TABLE — STACKED LABELS */
.detail-tbl { width: 100%; border-collapse: collapse; }
.detail-tbl td { border: 1px solid #bbb; padding: 4px 8px; vertical-align: top; font-size: 8.5px; }
.detail-tbl .stk-lbl { font-weight: bold; font-size: 7.5px; color: #2e6da4; text-transform: uppercase; letter-spacing: 0.4px; display: block; }
.detail-tbl .stk-val { font-size: 9.5px; font-weight: bold; color: #000; display: block; margin-top: 2px; }
.tracking-link {
color: #4a90c4; text-decoration: none; font-weight: bold;
border-bottom: 1px dashed #4a90c4;
}

/* PROBLEM + CHECKLIST COMBO */
.combo-tbl { width: 100%; border-collapse: collapse; font-size: 8px; table-layout: fixed; }
.combo-tbl th {
background: #4a90c4; color: #fff;
border: 1px solid #000; padding: 3px 5px;
text-align: center; font-weight: bold;
font-size: 8px; text-transform: uppercase; letter-spacing: 0.3px;
}
.combo-tbl td { border: 1px solid #bbb; padding: 0 6px; vertical-align: middle; height: 22px; }
.combo-tbl .problem-row td { background: #fff8e1; border-bottom: 2px solid #4a90c4; font-size: 9px; height: 28px; font-weight: bold; color: #000; }
.combo-tbl .problem-lbl { font-weight: bold; color: #000; background: #f0f4f8 !important; }
.combo-tbl .chk-no { text-align: center; width: 6%; }
.combo-tbl .chk-cat { width: 18%; }
.combo-tbl .chk-point { width: 28%; }
.combo-tbl .chk-status { text-align: center; width: 14%; }
.combo-tbl .chk-remark { width: 34%; }
.combo-tbl tr:nth-child(even) td { background: #fafafa; }
.combo-tbl tr.problem-row td { background: #fff8e1 !important; }
.status-bad { color: #c0392b; font-weight: bold; }
.status-partial { color: #e67e22; font-weight: bold; }

/* DAMAGED PARTS */
.parts-tbl { width: 100%; border-collapse: collapse; font-size: 8.5px; table-layout: fixed; }
.parts-tbl th {
background: #4a90c4; color: #fff;
border: 1px solid #000; padding: 3px 6px;
text-align: left; font-weight: bold;
text-transform: uppercase; letter-spacing: 0.3px; font-size: 8px;
}
.parts-tbl td { border: 1px solid #bbb; padding: 3px 7px; vertical-align: middle; height: 20px; }
.parts-tbl tr:nth-child(even) td { background: #fafafa; }
.part-name { font-weight: bold; color: #2e6da4; }
.severity-High { color: #c0392b; font-weight: bold; text-align: center; }
.severity-Medium { color: #e67e22; font-weight: bold; text-align: center; }
.severity-Low { color: #27ae60; font-weight: bold; text-align: center; }

/* TERMS + STAMP */
.bottom-wrap { width: 100%; border-collapse: collapse; margin-top: 4px; page-break-inside: avoid; }
.bottom-wrap td { border: 1px solid #000; vertical-align: top; padding: 0; }
.terms-wrap { font-size: 7.5px; line-height: 1.3; padding: 4px 7px; }
.terms-title { font-size: 8.5px; font-weight: bold; text-decoration: underline; margin-bottom: 2px; }
.terms-section { font-weight: bold; font-size: 7.5px; margin-top: 3px; color: #4a90c4; }
.terms-wrap p { margin-bottom: 1px; }
.stamp-wrap { text-align: center; vertical-align: bottom; padding: 5px 5px; }
.sig-space { height: 50px; border-bottom: 1px solid #000; margin: 6px 8px 3px; }

/* APPENDIX */
.appendix-outer { margin-top: 4px; margin-bottom: 4px; border: 1px solid #000; }
.appendix-bar {
background: #4a90c4; color: #fff;
padding: 3px 8px; font-size: 9px; font-weight: bold;
letter-spacing: 0.5px; text-transform: uppercase;
}
.appendix-label {
font-size: 8px; font-weight: bold; color: #2e6da4;
text-transform: uppercase; letter-spacing: 0.5px;
padding: 3px 8px 2px;
border-bottom: 1px solid #ddd;
background: #f0f4f8;
}
.appendix-photo-area { width: 100%; min-height: 130px; padding: 6px 8px; }
.ap-item {
display: inline-block; vertical-align: top;
width: 47%; margin: 0 1% 10px 1%;
text-align: center;
border: 1px solid #ccc; padding: 6px;
background: #fff;
page-break-inside: avoid;
}
.ap-item img { max-width: 100%; max-height: 260px; display: block; margin: 0 auto 4px; }
.ap-cap { font-size: 9.5px; font-weight: bold; color: #000; }
.ap-cap .ap-no { color: #c0392b; }
.ap-empty { font-size: 8.5px; color: #777; padding: 8px 2px; }
</style>
</head>
<body>
<div class="page">

{# ── WATERMARK (LARGE) ─────────────────────────────────────────── #}
<div class="watermark">
<img src="/files/logo.png" alt="Watermark">
</div>

<div class="content">

<div class="hdr-copy">Original For Recipient</div>
<div class="hdr-title">REPAIR MERCHANDISE AUTHORIZATION</div>

{# ── HEADER ────────────────────────────────────────────────────── #}
<table class="hdr-tbl">
<tr>
<td class="hdr-logo-cell">
<img src="/files/logo.png" alt="Logo" class="hdr-logo-img">
</td>
<td style="width:60%; text-align:center; vertical-align:middle;">
<div class="hdr-company">{{ doc.company_name or "InsideFPV Ventures Pvt. Ltd." }}</div>
<div class="hdr-addr">415, Shavion Shopping Paradise, Gaurav Path Road, Adajan, Surat, Gujarat – 395009, India</div>
</td>
<td style="width:22%; vertical-align:middle;"></td>
</tr>
</table>
<hr class="hdr-divider">
<div class="hdr-contact">
☎ 08040138038 &nbsp;|&nbsp;
✉ contact@insidefpv.com &nbsp;|&nbsp;
GSTIN: {{ doc.gstin or "24AAGCI3721B1Z6" }}
</div>

{# ── RMA META BAND — LABELS ABOVE VALUES ───────────────────────── #}
<table class="rma-meta">
<tr>
<td>
<span class="meta-lbl">RMA Number</span>
<span class="meta-val">{{ doc.name }}</span>
</td>
</tr>
<tr>
<td class="highlight-cell">
<span class="meta-lbl">Customer</span>
<span class="meta-val">{{ doc.customer }}</span>
</td>
</tr>
<tr>
<td>
<span class="meta-lbl">Sales Order</span>
<span class="meta-val">{{ doc.sales_order or '—' }}</span>
</td>
</tr>
<tr>
<td class="highlight-cell">
<span class="meta-lbl">Date of Receive</span>
<span class="meta-val">{{ frappe.format_date(doc.receive_date) }}</span>
</td>
</tr>
</table>

{# ── ITEM DETAILS — STACKED LABELS ─────────────────────────────── #}
<div class="sec-bar">Item Details</div>
<table class="detail-tbl">
<tr>
<td>
<span class="stk-lbl">Item / Product</span>
<span class="stk-val">{{ doc.item or '—' }}</span>
</td>
</tr>
<tr>
<td>
<span class="stk-lbl">Serial Number</span>
<span class="stk-val">{{ doc.serial_number or '—' }}</span>
</td>
</tr>
<tr>
<td>
<span class="stk-lbl">Delivery Tracking</span>
<span class="stk-val">
{% if doc.delivery_tracking %}
<a href="{{ doc.get('delivery_tracking_url') or doc.delivery_tracking }}" class="tracking-link">{{ doc.delivery_tracking }} ↗</a>
{% else %}
—
{% endif %}
</span>
</td>
</tr>
</table>

{# ── PROBLEM DESCRIPTION + INSPECTION CHECKLIST ────────────────── #}
<div class="sec-bar">Problem Description &amp; Inspection Checklist</div>
<table class="combo-tbl">

{# Problem description row #}
<tr class="problem-row">
<td class="problem-lbl" style="width:18%; padding:0 6px;">Problem Description</td>
<td colspan="4" style="padding:4px 8px;">{{ doc.problem_description }}</td>
</tr>

{# Checklist header #}
<tr>
<th class="chk-no">No.</th>
<th class="chk-cat">Category</th>
<th class="chk-point">Checkpoint</th>
<th class="chk-status">Status</th>
<th class="chk-remark">Remarks</th>
</tr>

{# Loop over inspection child table — show any row whose status contains "damag" (Damaged/Damage etc.), OK rows ignored #}
{% set ns = namespace(idx=1) %}
{% for row in doc.get("rma_inspection") or [] %}
{% if "damag" in (row.get("working_status") or "") | lower %}
<tr>
<td class="chk-no">{{ ns.idx }}</td>
<td class="chk-cat">{{ row.category }}</td>
<td class="chk-point">{{ row.checkpoint }}</td>
<td class="chk-status status-bad">
{{ row.working_status }}
</td>
<td class="chk-remark">{% if row.remarks %}<b>{{ row.remarks }}</b>{% endif %}</td>
</tr>
{% set ns.idx = ns.idx + 1 %}
{% endif %}
{% endfor %}

</table>

{# ── DAMAGED PARTS SUMMARY (only renders if the table exists & has rows) ── #}
{% if doc.get("damaged_parts") %}
<div class="sec-bar">Damaged Parts Summary</div>
<table class="parts-tbl">
<tr>
<th style="width:5%; text-align:center;">No.</th>
<th style="width:26%;">Part Name</th>
<th style="width:34%;">Damage Description</th>
<th style="width:13%; text-align:center;">Severity</th>
<th style="width:22%;">Action Required</th>
</tr>
{% for row in doc.damaged_parts %}
<tr>
<td style="text-align:center;">{{ loop.index }}</td>
<td class="part-name">{{ row.part_name }}</td>
<td>{{ row.damage_description }}</td>
<td class="severity-{{ row.severity }}">{{ row.severity }}</td>
<td>{{ row.action_required }}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{# ── APPENDIX ──────────────────────────────────────────────────── #}
<div class="appendix-outer">
<div class="appendix-bar">Appendix</div>
<div class="appendix-label">Inspection Photos</div>
<div class="appendix-photo-area">
{# Same filter & numbering as the checklist above, so photo numbers match table row numbers #}
{% set ap = namespace(idx=1, shown=0) %}
{% for row in doc.get("rma_inspection") or [] %}
{% if "damag" in (row.get("working_status") or "") | lower %}
{% if row.get("damage_photo") %}
<div class="ap-item">
<img src="{{ row.damage_photo }}" alt="Damage Photo {{ ap.idx }}">
<div class="ap-cap"><span class="ap-no">No. {{ ap.idx }}</span> — {{ row.checkpoint }}</div>
</div>
{% set ap.shown = ap.shown + 1 %}
{% endif %}
{% set ap.idx = ap.idx + 1 %}
{% endif %}
{% endfor %}
{% if ap.shown == 0 %}
<div class="ap-empty">No inspection photos attached.</div>
{% endif %}
</div>
</div>

{# ── TERMS & CONDITIONS + STAMP ────────────────────────────────── #}
<table class="bottom-wrap">
<tr>
<td style="width:74%;" class="terms-wrap">
<div class="terms-title">Terms &amp; Conditions</div>

<div class="terms-section">Address:</div>
<p>415, Shavion Shopping Paradise, Gaurav Path Road, Adajan, Surat, Gujarat – 395009, India &nbsp;|&nbsp; GSTIN: {{ doc.gstin or "24AAGCI3721B1Z6" }} &nbsp;|&nbsp; Contact: 08040138038</p>

<div class="terms-section">Payment Terms:</div>
<p>Full payment is required in advance prior to commencement of services or delivery of products. The quoted amount must be paid within 7 days of acceptance.</p>

<div class="terms-section">Delivery Period:</div>
<p>Estimated delivery is 30 business days from date of receipt of full payment.</p>

<div class="terms-section">General:</div>
<p>Goods once sold will not be taken back or exchanged. Delayed payments attract interest @18% p.a. All disputes subject to Surat jurisdiction only. E &amp; O.E.</p>
</td>
<td style="width:26%; border-left:1px solid #000;" class="stamp-wrap">
<strong style="font-size:9px;">For {{ doc.company_name or "InsideFPV Ventures Pvt. Ltd." }}</strong><br><br>
<svg width="65" height="65" viewBox="0 0 75 75" xmlns="http://www.w3.org/2000/svg">
<circle cx="37" cy="37" r="34" fill="none" stroke="#4a90c4" stroke-width="2.5"/>
<circle cx="37" cy="37" r="28" fill="none" stroke="#4a90c4" stroke-width="1"/>
<text x="37" y="20" font-family="Arial" font-size="6" fill="#4a90c4" text-anchor="middle" font-weight="bold">InsideFPV</text>
<text x="37" y="29" font-family="Arial" font-size="5.5" fill="#4a90c4" text-anchor="middle">Ventures Pvt. Ltd.</text>
<text x="37" y="41" font-family="Arial" font-size="10" fill="#4a90c4" text-anchor="middle" font-weight="bold">SURAT</text>
<text x="37" y="51" font-family="Arial" font-size="5.5" fill="#4a90c4" text-anchor="middle">Gujarat, India</text>
<text x="37" y="62" font-family="Arial" font-size="7" fill="#4a90c4" text-anchor="middle">★★★</text>
</svg>
<div class="sig-space"></div>
<div style="font-size:8.5px;">Authorised Signatory</div>
</td>
</tr>
</table>

</div>
</div>
</body>
</html>
